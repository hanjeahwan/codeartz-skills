{
  "id": "create-draft",
  "skill": "project-foundation",
  "tier": "smoke",
  "description": "没有项目知识基础时先建立当前草稿，不提前创建正式文件。",
  "files": {
    "package.json": "{\n  \"scripts\": {\n    \"test\": \"node --test\"\n  }\n}\n",
    "src/catalog.ts": "export function findProduct(id: string): string | undefined {\n  return id === 'p1' ? 'Keyboard' : undefined;\n}\n",
    "test/catalog.test.ts": "import assert from 'node:assert/strict';\nimport test from 'node:test';\nimport { findProduct } from '../src/catalog.ts';\n\ntest('找不到商品时返回 undefined', () => {\n  assert.equal(findProduct('missing'), undefined);\n});\n"
  },
  "turns": [
    {
      "prompt": "$project-foundation 帮这个没有 AGENTS.md、CLAUDE.md 和项目规范文档的仓库建立项目知识基础。先诊断并准备草稿；我还没有批准创建任何正式文件。",
      "checks": [
        { "type": "responseIncludes", "value": "草稿" },
        { "type": "responseMatches", "pattern": "(?:待裁决|批准)" }
      ]
    }
  ],
  "postChecks": [
    { "type": "fileExists", "path": ".codeartz/project-foundation/draft.md" },
    { "type": "fileContains", "path": ".codeartz/project-foundation/draft.md", "value": "## 检查范围" },
    { "type": "fileContains", "path": ".codeartz/project-foundation/draft.md", "value": "## 建议变更" },
    { "type": "fileContains", "path": ".codeartz/project-foundation/draft.md", "value": "## 待裁决" },
    { "type": "fileContains", "path": ".codeartz/project-foundation/draft.md", "value": "## 最终内容" },
    { "type": "fileContains", "path": ".codeartz/project-foundation/draft.md", "value": "## 验证计划" },
    {
      "type": "markdownHeadingsEqual",
      "path": ".codeartz/project-foundation/draft.md",
      "level": 2,
      "headings": ["检查范围", "建议变更", "待裁决", "最终内容", "验证计划"]
    },
    {
      "type": "fileContains",
      "path": ".codeartz/project-foundation/draft.md",
      "value": "docs/project-foundation-baseline.json"
    },
    { "type": "fileNotExists", "path": "AGENTS.md" },
    { "type": "fileNotExists", "path": "CLAUDE.md" },
    { "type": "fileNotExists", "path": "docs/architecture.md" },
    { "type": "trajectoryIncludes", "value": "project-foundation" }
  ],
  "criteria": [
    "回应先检查代码、配置和测试，再建立可跨会话跟踪的当前草稿。",
    "每个建议变更把精确内容、依据和不确定性放在一起。",
    "草稿根据知识职责、适用范围和读取情境提出最小目标结构。",
    "用户没有批准正式文件，因此没有创建 AGENTS.md、CLAUDE.md 或 docs 规范。"
  ]
}
