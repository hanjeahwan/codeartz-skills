{
  "id": "refresh-knowledge",
  "skill": "project-foundation",
  "tier": "full",
  "description": "刷新时同时对账已有知识，并发现代码演进产生的新知识。",
  "files": {
    "AGENTS.md": "# 项目 Agent 指南\n\n## 验证\n\n- 修改代码后运行 `npm test`。\n",
    "package.json": "{\n  \"scripts\": {\n    \"check\": \"node --check src/index.js\",\n    \"test:unit\": \"node --test\"\n  }\n}\n",
    "src/index.js": "export const locale = 'zh-CN';\n",
    "locales/zh-CN.json": "{\"catalog.empty\":\"暂无商品\"}\n",
    "docs/project-foundation-baseline.json": "{\n  \"version\": 1,\n  \"sourceCommit\": null,\n  \"knowledgeFiles\": [\"AGENTS.md\"]\n}\n"
  },
  "turns": [
    {
      "prompt": "$project-foundation 刷新项目知识。检查已有知识是否过时，也检查代码演进产生的新知识；先更新草稿，不修改正式文件。",
      "checks": [
        { "type": "responseMatches", "pattern": "(?:对账|漂移|失效)" },
        { "type": "responseMatches", "pattern": "(?:国际化|新知识)" }
      ]
    }
  ],
  "postChecks": [
    { "type": "fileUnchanged", "path": "AGENTS.md" },
    { "type": "fileUnchanged", "path": "docs/project-foundation-baseline.json" },
    { "type": "fileContains", "path": ".codeartz/project-foundation/draft.md", "value": "test:unit" },
    { "type": "fileContains", "path": ".codeartz/project-foundation/draft.md", "value": "国际化" },
    { "type": "fileContains", "path": ".codeartz/project-foundation/draft.md", "value": "## 建议变更" },
    { "type": "fileContains", "path": ".codeartz/project-foundation/draft.md", "value": "## 待裁决" },
    { "type": "fileContains", "path": ".codeartz/project-foundation/draft.md", "value": "## 最终内容" },
    { "type": "fileContains", "path": ".codeartz/project-foundation/draft.md", "value": "## 验证计划" },
    {
      "type": "markdownHeadingsEqual",
      "path": ".codeartz/project-foundation/draft.md",
      "level": 2,
      "headings": ["检查范围", "建议变更", "待裁决", "最终内容", "验证计划"]
    },
    { "type": "markdownFencesBalanced", "path": ".codeartz/project-foundation/draft.md" },
    { "type": "trajectoryIncludes", "value": "project-foundation" }
  ],
  "criteria": [
    "回应发现 AGENTS.md 中的 npm test 已失去当前配置证据。",
    "回应还从 locales 与代码发现新的国际化知识主题。",
    "刷新使用最小长期基线并执行结构复查。",
    "所有建议只进入草稿，正式知识与长期基线保持不变。"
  ]
}
