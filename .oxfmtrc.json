{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "singleQuote": true,
  "semi": true,
  "trailingComma": "all",
  "ignorePatterns": ["**/node_modules/**"],
  "objectWrap": "preserve",
  "quoteProps": "consistent",
  "sortImports": true,
  "sortPackageJson": true
}
